<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Sambhi Mobiles — CRM</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--b:#2563EB;--g:#16A34A;--r:#DC2626;--o:#F97316;--p:#7C3AED;--y:#D97706;--gray:#F8FAFC;--border:#E2E8F0;--text:#0F172A;--muted:#64748B}
body{font-family:system-ui,sans-serif;background:var(--gray);color:var(--text);font-size:14px}
/* TOP */
#top{background:#fff;border-bottom:1px solid var(--border);height:54px;display:flex;align-items:center;justify-content:space-between;padding:0 20px;position:sticky;top:0;z-index:50;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.tlogo{font-size:16px;font-weight:800}
.tlogo span{color:var(--b)}
.tright{display:flex;align-items:center;gap:10px}
.tav{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:#fff}
.tname{font-size:13px;font-weight:600;color:#334155}
.trole{font-size:10px;color:#94A3B8}
#newbadge{background:var(--r);color:#fff;font-size:11px;font-weight:700;padding:4px 10px;border-radius:100px;border:none;cursor:pointer;font-family:inherit}
#logoutbtn{background:#F1F5F9;color:#64748B;border:none;padding:6px 12px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit}
/* TABS */
#tabs{background:#fff;border-bottom:1px solid var(--border);display:flex;overflow-x:auto;padding:0 16px}
.tb{padding:12px 13px;font-size:13px;font-weight:600;cursor:pointer;border:none;background:transparent;color:#94A3B8;border-bottom:2.5px solid transparent;white-space:nowrap;font-family:inherit}
.tb.on{color:var(--b);border-bottom-color:var(--b)}
.nb{display:inline-flex;align-items:center;justify-content:center;background:var(--r);color:#fff;font-size:10px;font-weight:700;min-width:17px;height:17px;border-radius:100px;margin-left:4px;padding:0 3px}
/* PAGES */
.pg{display:none;padding:18px;max-width:1300px;margin:0 auto}.pg.on{display:block}
/* STATS */
.stats{display:grid;grid-template-columns:repeat(5,1fr);gap:11px;margin-bottom:18px}
.stat{background:#fff;border:1px solid var(--border);border-radius:11px;padding:15px;cursor:pointer}
.stat:hover{box-shadow:0 3px 10px rgba(0,0,0,.07)}
.stat .n{font-size:26px;font-weight:800;line-height:1;margin-bottom:3px}
.stat .l{font-size:11px;color:#94A3B8}
/* TABLE */
.tw{background:#fff;border:1px solid var(--border);border-radius:13px;overflow:hidden}
.ttop{padding:11px 15px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);flex-wrap:wrap;gap:8px}
.ttop h3{font-size:14px;font-weight:700}
.tbar{display:flex;gap:7px;flex-wrap:wrap;align-items:center}
.si{border:1.5px solid var(--border);border-radius:8px;padding:7px 10px;font-size:13px;font-family:inherit;outline:none;background:#F8FAFC}
.si:focus{border-color:var(--b)}
.ab{background:var(--b);color:#fff;border:none;padding:7px 13px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit}
table{width:100%;border-collapse:collapse}
thead th{background:#F8FAFC;font-size:11px;font-weight:700;color:#94A3B8;text-transform:uppercase;letter-spacing:.4px;padding:9px 12px;text-align:left;border-bottom:1px solid var(--border)}
tbody tr{border-bottom:1px solid var(--border);cursor:pointer;transition:background .12s}
tbody tr:last-child{border:none}
tbody tr:hover{background:#EFF6FF}
td{padding:10px 12px;font-size:13px;vertical-align:middle}
.badge{display:inline-flex;font-size:11px;font-weight:700;padding:3px 9px;border-radius:100px}
.st-new{background:#EFF6FF;color:var(--b)}.st-contacted{background:#FFFBEB;color:var(--y)}.st-scheduled{background:#EDE9FE;color:var(--p)}.st-completed{background:#F0FDF4;color:var(--g)}.st-cancelled{background:#FEF2F2;color:var(--r)}
.sm{font-size:11px;font-weight:600;padding:2px 7px;border-radius:100px;background:#FEF3C7;color:#92400E}
.se{font-size:11px;font-weight:600;padding:2px 7px;border-radius:100px;background:#EDE9FE;color:var(--p)}
.act{font-size:11px;font-weight:600;padding:5px 8px;border-radius:6px;border:none;cursor:pointer;font-family:inherit}
.ac{background:#F0FDF4;color:var(--g)}.ac:hover{background:var(--g);color:#fff}
.aw{background:#DCFCE7;color:#166534}.aw:hover{background:var(--g);color:#fff}
.ad{background:#FEF2F2;color:var(--r)}.ad:hover{background:var(--r);color:#fff}
.abi{background:var(--b);color:#fff}.abi:hover{background:#1d4ed8}.abi:disabled{background:#F1F5F9;color:#94A3B8;cursor:not-allowed}
/* MODAL */
.mbg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:200;align-items:center;justify-content:center;padding:16px;backdrop-filter:blur(3px)}
.mbg.on{display:flex}
.modal{background:#fff;border-radius:16px;width:100%;max-width:560px;max-height:90vh;overflow-y:auto;box-shadow:0 16px 48px rgba(0,0,0,.2)}
.mh{padding:15px 18px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);position:sticky;top:0;background:#fff;z-index:1}
.mh h2{font-size:15px;font-weight:700}
.mx{background:#F1F5F9;border:none;width:27px;height:27px;border-radius:50%;cursor:pointer;font-size:13px;font-family:inherit}
.mb{padding:16px 18px 20px}
.fg{margin-bottom:12px}
.fg label{display:block;font-size:11px;font-weight:700;color:#64748B;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px}
.fg input,.fg select,.fg textarea{width:100%;border:1.5px solid var(--border);border-radius:8px;padding:9px 11px;font-size:13px;font-family:inherit;outline:none;background:#F8FAFC;-webkit-appearance:none}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--b);background:#fff}
.fg textarea{resize:none;height:58px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px}
.sb{width:100%;background:var(--b);color:#fff;border:none;padding:11px;border-radius:9px;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;margin-top:4px}
.sb:hover{background:#1d4ed8}
.sl{font-size:10px;font-weight:700;color:var(--b);text-transform:uppercase;letter-spacing:.7px;margin:13px 0 7px;padding-bottom:5px;border-bottom:1px solid var(--border);display:block}
.pb{background:#0F172A;border-radius:10px;padding:12px 15px;margin:11px 0;display:flex;justify-content:space-between;align-items:center}
.pbv{font-size:21px;font-weight:800;color:#fff}
.pbl{font-size:11px;color:rgba(255,255,255,.4);margin-bottom:2px}
.pbs{font-size:10px;color:rgba(255,255,255,.3);margin-top:1px}
.dc{display:flex;flex-wrap:wrap;gap:6px}
.chip{display:flex;align-items:center;gap:5px;border:1.5px solid var(--border);border-radius:7px;padding:6px 10px;cursor:pointer;font-size:12px;color:#64748B;background:#fff;user-select:none;transition:all .12s}
.chip:hover{border-color:var(--r);color:var(--r)}
.chip.on{border-color:var(--r);background:#FEF2F2;color:var(--r);font-weight:700}
.cd{width:6px;height:6px;border-radius:50%;background:var(--border);flex-shrink:0}
.chip.on .cd{background:var(--r)}
.stpr{display:flex;border-radius:8px;overflow:hidden;border:1px solid var(--border);margin-bottom:12px}
.sp{flex:1;padding:8px 4px;border:none;background:#F8FAFC;font-size:11px;font-weight:600;cursor:pointer;font-family:inherit;color:#94A3B8;border-right:1px solid var(--border);text-align:center}
.sp:last-child{border-right:none}
.sp:hover{background:#F1F5F9}
.sp.active{background:var(--b);color:#fff}
.sp.done{background:#F0FDF4;color:var(--g)}
.tl{display:flex;flex-direction:column;gap:7px;margin-bottom:9px}
.tli{background:#F8FAFC;border-radius:7px;padding:8px 10px;display:flex;gap:8px}
.tld{width:7px;height:7px;border-radius:50%;background:var(--b);flex-shrink:0;margin-top:4px}
.tlt{font-size:12px;color:#334155}
.tlm{font-size:10px;color:#94A3B8;margin-top:1px}
.nr{display:flex;gap:6px;margin-top:8px}
.nr input{flex:1;border:1.5px solid var(--border);border-radius:7px;padding:8px 10px;font-size:13px;font-family:inherit;outline:none}
.nr input:focus{border-color:var(--b)}
.nr button{background:var(--b);color:#fff;border:none;padding:8px 12px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit}
/* KANBAN */
.kan{display:grid;grid-template-columns:repeat(4,1fr);gap:11px}
.kc{background:#fff;border:1px solid var(--border);border-radius:11px;overflow:hidden;min-height:140px}
.kh{padding:9px 11px;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border)}
.kn{font-size:10px;font-weight:700;padding:2px 7px;border-radius:100px}
.kc-new .kh{background:#EFF6FF;color:var(--b)}.kc-new .kn{background:var(--b);color:#fff}
.kc-con .kh{background:#FFFBEB;color:var(--y)}.kc-con .kn{background:var(--y);color:#fff}
.kc-sch .kh{background:#EDE9FE;color:var(--p)}.kc-sch .kn{background:var(--p);color:#fff}
.kc-don .kh{background:#F0FDF4;color:var(--g)}.kc-don .kn{background:var(--g);color:#fff}
.kb{padding:8px;display:flex;flex-direction:column;gap:6px}
.kcard{background:#F8FAFC;border:1px solid var(--border);border-radius:9px;padding:9px;cursor:pointer}
.kcard:hover{border-color:var(--b);background:#EFF6FF}
.kcard h4{font-size:12px;font-weight:700;margin-bottom:2px}
.kdev{font-size:11px;color:#94A3B8;margin-bottom:5px}
.ktags{display:flex;gap:3px;flex-wrap:wrap}
.ktag{font-size:10px;font-weight:600;padding:2px 6px;border-radius:100px;background:#F1F5F9;color:#64748B}
/* RIDERS */
.rg{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.rc{background:#fff;border:1.5px solid var(--border);border-radius:12px;padding:16px;text-align:center}
.rav{width:46px;height:46px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:800;color:#fff;margin:0 auto 9px}
/* CAMPAIGNS */
.cg{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.cc{background:#fff;border:1.5px solid var(--border);border-radius:12px;padding:16px}
.cc.live{border-color:var(--o)}
.che{display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:9px}
.ctit{font-size:14px;font-weight:700}
.cdesc{font-size:12px;color:#64748B;margin-top:2px}
.tog{position:relative;width:44px;height:24px;flex-shrink:0}
.tog input{position:absolute;opacity:0;width:100%;height:100%;cursor:pointer;z-index:1;margin:0}
.tt{position:absolute;inset:0;background:#E2E8F0;border-radius:100px;transition:background .2s}
.tog input:checked+.tt{background:var(--o)}
.th{position:absolute;top:3px;left:3px;width:18px;height:18px;background:#fff;border-radius:50%;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.2)}
.tog input:checked~.th{transform:translateX(20px)}
.clive{font-size:12px;font-weight:700;color:#fff;background:var(--o);padding:4px 10px;border-radius:7px;display:inline-block;margin-bottom:7px}
.cdates{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin:7px 0}
.cdates label{font-size:10px;font-weight:700;color:#94A3B8;display:block;margin-bottom:3px}
.cdates input{width:100%;border:1.5px solid var(--border);border-radius:7px;padding:6px 8px;font-size:12px;font-family:inherit;outline:none}
.cwa{font-size:11px;color:#64748B;background:#F8FAFC;border-radius:7px;padding:7px;margin-bottom:7px;line-height:1.5}
/* INVENTORY */
.ig{display:grid;grid-template-columns:repeat(3,1fr);gap:13px}
.ic{background:#fff;border:1.5px solid var(--border);border-radius:13px;overflow:hidden;transition:all .2s}
.ic:hover{box-shadow:0 4px 14px rgba(0,0,0,.08)}
.ith{height:130px;background:#F8FAFC;display:flex;align-items:center;justify-content:center;position:relative}
.ith .iem{font-size:52px}
.ibadges{position:absolute;top:7px;left:7px;display:flex;gap:4px;flex-wrap:wrap}
.ibadges span{font-size:10px;font-weight:700;padding:2px 7px;border-radius:100px}
.ga{background:#F0FDF4;color:var(--g)}.gb{background:#EFF6FF;color:var(--b)}.gc{background:#FFFBEB;color:var(--y)}
.invis{background:#EDE9FE;color:var(--p)}
.cso{position:absolute;inset:0;background:rgba(0,0,0,.4);display:flex;align-items:center;justify-content:center}
.cstag{background:var(--p);color:#fff;font-size:12px;font-weight:700;padding:5px 11px;border-radius:100px}
.ibo{padding:13px}
.ic h4{font-size:14px;font-weight:700;margin-bottom:2px}
.isp{font-size:12px;color:#94A3B8;margin-bottom:7px}
.ipr{font-size:19px;font-weight:800;color:var(--b)}
.imrp{font-size:12px;color:#CBD5E1;text-decoration:line-through;margin-left:5px}
.ibt{display:flex;gap:5px;margin-top:9px;flex-wrap:wrap}
.ib{font-size:11px;font-weight:600;padding:4px 9px;border-radius:6px;border:none;cursor:pointer;font-family:inherit}
.ibs{background:#F0FDF4;color:var(--g)}.ibh{background:#F8FAFC;color:#64748B;border:1px solid var(--border)}.ibe{background:#EFF6FF;color:var(--b)}.ibd{background:#FEF2F2;color:var(--r)}
.nform{padding:11px 13px;background:#F3E8FF;border-top:1px solid var(--border)}
.nform input{width:100%;border:1.5px solid #DDD6FE;border-radius:7px;padding:7px 9px;font-size:12px;font-family:inherit;outline:none;margin-bottom:5px;background:#fff}
.nform button{width:100%;background:var(--p);color:#fff;border:none;padding:7px;border-radius:7px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit}
/* PRICES */
.pcard{background:#fff;border:1px solid var(--border);border-radius:13px;padding:20px;max-width:520px;margin-bottom:14px}
.pcard h3{font-size:15px;font-weight:700;margin-bottom:5px}
.pcard p{font-size:13px;color:#64748B;margin-bottom:16px}
.psr{display:flex;align-items:center;gap:11px;margin-bottom:13px}
.psr input{flex:1;accent-color:var(--b)}
.psv{font-size:17px;font-weight:800;color:var(--b);min-width:52px}
.pex{background:#EFF6FF;border-radius:8px;padding:10px;font-size:13px;color:var(--b);margin-bottom:13px}
/* TEAM */
.tg{display:grid;grid-template-columns:repeat(3,1fr);gap:13px}
.tc{background:#fff;border:1.5px solid var(--border);border-radius:13px;padding:18px;text-align:center}
.tav2{width:50px;height:50px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:19px;font-weight:800;color:#fff;margin:0 auto 9px}
.tc h3{font-size:14px;font-weight:700;margin-bottom:3px}
.tr{font-size:11px;font-weight:700;padding:3px 10px;border-radius:100px;display:inline-block;margin-bottom:9px}
.tro{background:#FFFBEB;color:var(--y)}.trm{background:#EFF6FF;color:var(--b)}.tre{background:#F0FDF4;color:var(--g)}
.ti{font-size:11px;color:#64748B;margin-bottom:2px}
.teb{width:100%;background:#F1F5F9;color:#334155;border:none;padding:7px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;margin-top:7px}
.teb:hover{background:var(--b);color:#fff}
/* BILL */
.bc2{display:grid;grid-template-columns:1fr 1fr;gap:15px;align-items:start}
.bcard{background:#fff;border:1px solid var(--border);border-radius:13px;padding:18px}
.bcard h3{font-size:14px;font-weight:700;margin-bottom:13px}
.binfo{background:#F0FDF4;border:1px solid rgba(22,163,74,.2);border-radius:8px;padding:9px 11px;font-size:12px;color:var(--g);margin-bottom:11px}
.txbox{background:#0F172A;border-radius:10px;padding:12px 14px;margin:11px 0}
.txr{display:flex;justify-content:space-between;margin-bottom:5px;font-size:12px}
.txl{color:rgba(255,255,255,.4)}.txv{color:#fff;font-weight:600}
.txg{display:flex;justify-content:space-between;border-top:1px solid rgba(255,255,255,.1);padding-top:9px;margin-top:3px}
.txgl{font-size:13px;font-weight:700;color:var(--o)}
.txgv{font-size:20px;font-weight:800;color:#fff}
.bhi{background:#F8FAFC;border-radius:9px;padding:10px 12px;display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;border:1px solid var(--border)}
/* LOYALTY */
.loybox{background:#FFFBEB;border:1.5px solid #FCD34D;border-radius:8px;padding:10px 12px;display:flex;align-items:center;gap:9px;cursor:pointer;margin-bottom:11px}
.loybox h4{font-size:13px;font-weight:700;color:var(--y);margin-bottom:1px}
.loybox p{font-size:11px;color:#B45309}
#toast{position:fixed;bottom:18px;right:18px;padding:9px 15px;border-radius:10px;font-size:13px;font-weight:600;z-index:999;transform:translateY(50px);opacity:0;transition:all .3s;pointer-events:none}
#toast.on{transform:translateY(0);opacity:1}
#toast.s{background:var(--g);color:#fff}
#toast.e{background:var(--r);color:#fff}
#toast.i{background:var(--b);color:#fff}
@media(max-width:900px){.stats{grid-template-columns:repeat(3,1fr)}.kan{grid-template-columns:1fr 1fr}.bc2,.cg,.tg,.rg{grid-template-columns:1fr}.ig{grid-template-columns:1fr 1fr}}
@media(max-width:600px){.stats{grid-template-columns:1fr 1fr}.kan{grid-template-columns:1fr}.ig{grid-template-columns:1fr}.g2,.g3{grid-template-columns:1fr}}
</style>
</head>
<body>
<div id="top">
  <div class="tlogo">Sambhi <span>Mobiles</span> — Admin</div>
  <div class="tright">
    <div class="tav" id="tav"></div>
    <div><div class="tname" id="tname"></div><div class="trole" id="trole"></div></div>
    <button id="newbadge" onclick="gt('leads')">🔔 0 New</button>
    <button id="logoutbtn" onclick="logout()">Logout</button>
  </div>
</div>
<div id="tabs">
  <button class="tb on" data-pg="dash">📊 Dashboard</button>
  <button class="tb" data-pg="leads">📋 Leads <span class="nb" id="nbl">0</span></button>
  <button class="tb" data-pg="fu">🔁 Follow-up</button>
  <button class="tb" data-pg="bill">🧾 Bill</button>
  <button class="tb" data-pg="add">➕ Add Lead</button>
  <button class="tb" data-pg="riders">🏍️ Riders</button>
  <button class="tb" data-pg="camps">🎯 Campaigns</button>
  <button class="tb" data-pg="inv">📦 Inventory</button>
  <button class="tb" data-pg="prices">💰 Prices</button>
  <button class="tb" data-pg="team">👥 Team</button>
</div>
<!-- PAGES -->
<div class="pg on" id="pg-dash">
  <div class="stats">
    <div class="stat" onclick="gt('leads')"><div class="n" id="s0" style="color:var(--b)">0</div><div class="l">New Today</div></div>
    <div class="stat" onclick="gt('fu')"><div class="n" id="s1" style="color:var(--y)">0</div><div class="l">Pending</div></div>
    <div class="stat" onclick="gt('fu')"><div class="n" id="s2" style="color:var(--p)">0</div><div class="l">Scheduled</div></div>
    <div class="stat" onclick="gt('leads')"><div class="n" id="s3" style="color:var(--g)">0</div><div class="l">Completed</div></div>
    <div class="stat"><div class="n" id="s4" style="color:var(--o)">₹0</div><div class="l">Paid Out</div></div>
  </div>
  <div class="tw">
    <div class="ttop"><h3>Recent Leads</h3><button class="ab" onclick="gt('add')">+ Add Lead</button></div>
    <table><thead><tr><th>Customer</th><th>Device</th><th>Area</th><th>Slot</th><th>Status</th><th>Est.</th><th>Actions</th></tr></thead>
    <tbody id="dtb"></tbody></table>
  </div>
</div>
<div class="pg" id="pg-leads">
  <div class="tw">
    <div class="ttop"><h3>All Leads</h3>
      <div class="tbar">
        <input class="si" id="src" placeholder="🔍 Search…" oninput="rl()">
        <select class="si" id="sst" onchange="rl()"><option value="">All Status</option><option value="new">New</option><option value="contacted">Contacted</option><option value="scheduled">Scheduled</option><option value="completed">Completed</option><option value="cancelled">Cancelled</option></select>
        <select class="si" id="ssl" onchange="rl()"><option value="">All Slots</option><option value="morning">Morning</option><option value="evening">Evening</option></select>
        <button class="ab" onclick="gt('add')">+ Add Lead</button>
      </div>
    </div>
    <table><thead><tr><th>Date</th><th>Customer</th><th>Phone</th><th>Device</th><th>Area</th><th>Slot</th><th>Status</th><th>Est.</th><th>Actions</th></tr></thead>
    <tbody id="ltb"></tbody></table>
  </div>
